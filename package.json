{
  "name": "termai",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "cd src/server && npm run dev",
    "dev:web": "cd src/web && npm run dev",
    "build": "cd src/server && npm run build && cd ../web && npm run build",
    "start": "cd src/server && npm run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
